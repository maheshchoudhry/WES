# WES OS — Company Engine (docker compose) environment
# Copy to `.env` for `docker compose up`. Values here are safe local defaults.

# --- PostgreSQL ---
POSTGRES_USER=wes
POSTGRES_PASSWORD=wes
POSTGRES_DB=wes_os
POSTGRES_PORT=5432

# --- Backend ---
# Seed the WES organization (1 company, 6 departments, 13 employees) on startup.
WES_SEED_ON_START=true
