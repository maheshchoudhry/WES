# WES OS — Company Engine frontend environment
# Copy to `.env`. Base URL of the backend API.
#
# Leave EMPTY to use the built-in /api proxy (Vite dev server, `vite preview`, or
# the nginx image in docker compose). This is the recommended setup — the app
# calls a relative /api path and the proxy forwards it to the backend.
#
# Set this ONLY if you serve the built app on a static host that does NOT proxy
# /api (e.g. `serve -s dist`). Point it at the backend, e.g. http://127.0.0.1:8000
VITE_API_BASE_URL=

# Backend origin the dev/preview server proxies /api to (development only).
# Use 127.0.0.1 (not localhost) to avoid IPv6/IPv4 resolution issues.
VITE_API_PROXY=http://127.0.0.1:8000
