# WES OS server environment. Generated by bootstrap.sh into /opt/wes/.env with
# unique random secrets (chmod 600). Never commit the generated file.

# --- Infrastructure (PostgreSQL + Redis containers) ---
POSTGRES_DB=wes_os
POSTGRES_USER=wes
POSTGRES_PASSWORD=__DB_PASSWORD__

REDIS_URL=redis://127.0.0.1:6379/0

# --- WES OS application (used when WES is deployed later) ---
WES_DATABASE_URL=postgresql+psycopg2://wes:__DB_PASSWORD__@127.0.0.1:5432/wes_os
WES_JWT_SECRET=__JWT_SECRET__
WES_SECRET_KEY=__SECRET_KEY__
WES_ENV=production
WES_AUTO_MIGRATE=true
WES_SEED_ON_START=true
WES_JOB_WORKER_ENABLED=true
WES_RATE_LIMIT_ENABLED=true

# --- Host / TLS ---
WES_DOMAIN=__DOMAIN__
