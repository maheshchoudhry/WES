# WES OS — Company Engine backend environment
# Copy to `.env` and adjust. No secrets are committed to the repository (Blueprint Vol. 04).

# --- Application ---
WES_APP_NAME="WES Company Engine"
WES_ENV=development
WES_API_V1_PREFIX=/api/v1
WES_DEBUG=true

# --- Database ---
# PostgreSQL is the production database (Blueprint Vol. 06).
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<db>
WES_DATABASE_URL=postgresql+psycopg2://wes:wes@localhost:5432/wes_os

# For local prototyping / tests, SQLite is supported:
# WES_DATABASE_URL=sqlite:///./wes_os.db

# --- CORS (frontend origin) ---
# Include both localhost and 127.0.0.1 so a directly-configured frontend origin
# is not blocked regardless of which host name the browser uses.
WES_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# --- Authentication / JWT (Sprint 04) ---
# WES_JWT_SECRET MUST be set to a strong random value in production.
WES_JWT_SECRET=dev-insecure-secret-change-in-production
WES_JWT_ALGORITHM=HS256
WES_ACCESS_TOKEN_MINUTES=30
WES_REFRESH_TOKEN_DAYS=7
WES_REFRESH_TOKEN_REMEMBER_DAYS=30
# Default password applied to seeded employees (local development only).
WES_SEED_DEFAULT_PASSWORD=WesOs2026!
